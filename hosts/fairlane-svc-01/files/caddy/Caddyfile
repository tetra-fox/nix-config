(lan_only) {
	@notlan not remote_ip private_ranges
	abort @notlan
}

(log) {
	log {
		output file /var/log/caddy/access.log
		format transform "{common_log}"
	}
}

{
	acme_dns cloudflare {$CF_TOKEN}
}

# public
fairlane.tetra.cool {
	import log
	respond "my paws hurt :("
}

jellyfin.fairlane.tetra.cool {
	import log
	route {
		import lan_only
		reverse_proxy localhost:8096
	}
}

stats.fairlane.tetra.cool {
	import log
	reverse_proxy localhost:3000
}

home.fairlane.tetra.cool {
	import log
	reverse_proxy 172.16.0.32:8123
}

# private
# sonarr/radarr/prowlarr/qbittorrent run in the wg netns; vpn-confinement DNATs their
# lanProxy ports onto the host-side bridge gateway, so caddy reaches them at 192.168.15.1.
# sabnzbd runs in the main namespace, so it's plain localhost.
qb.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy 192.168.15.1:8888
	}
}

sonarr.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy 192.168.15.1:8989
	}
}

radarr.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy 192.168.15.1:7878
	}
}

prowlarr.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy 192.168.15.1:9696
	}
}

sabnzbd.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy localhost:8080
	}
}
