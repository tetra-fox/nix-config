(lan_only) {
	@notlan not remote_ip private_ranges
	abort @notlan
}

(log) {
	log {
		output file /var/log/caddy/access.log
		format transform "{common_log}"
	}
}

{
	cert_issuer acme {
		dns cloudflare {$CF_TOKEN}
		resolvers 1.1.1.1 8.8.8.8
	}
}

# public
fairlane.tetra.cool {
	import log
	respond "my paws hurt :("
}

home.fairlane.tetra.cool {
	import log
	reverse_proxy 192.168.10.215:8123
}

jellyfin.fairlane.tetra.cool {
	import log
	reverse_proxy {$JELLYFIN_UPSTREAM}
}

stats.fairlane.tetra.cool {
	import log
	reverse_proxy {$STATS_UPSTREAM}
}

# private -- no authentik at fairlane, so the arr UIs are lan-only, no forward_auth. each
# proxies to its own port on the arr host ({$ARR_HOST}); the arr-stack DNATs the netns ports
# onto that host. sabnzbd is on the arr host too (8080).
qb.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy {$ARR_HOST}:8888
	}
}

sonarr.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy {$ARR_HOST}:8989
	}
}

radarr.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy {$ARR_HOST}:7878
	}
}

prowlarr.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy {$ARR_HOST}:9696
	}
}

sabnzbd.fairlane.tetra.cool {
	route {
		import lan_only
		reverse_proxy {$ARR_HOST}:8080
	}
}
