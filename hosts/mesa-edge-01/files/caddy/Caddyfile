(lan_only) {
	@notlan not remote_ip private_ranges
	abort @notlan
}

# common log format access log; imported by every site that should be
# subject to fail2ban. transform-encoder plugin produces apache-style logs
# (stable + simple-regex-friendly vs caddy's default JSON).
(log) {
	log {
		output file /var/log/caddy/access.log
		format transform "{common_log}"
	}
}

(authentik) {
	reverse_proxy /outpost.goauthentik.io/* {$AUTH_UPSTREAM} {
		header_up Host {http.reverse_proxy.upstream.hostport}
	}

	forward_auth {$AUTH_UPSTREAM} {
		uri /outpost.goauthentik.io/auth/caddy
		copy_headers Authorization
	}
}

{
	cert_issuer acme {
		dns cloudflare {$CF_TOKEN}
		resolvers 1.1.1.1 8.8.8.8
	}
}

# public
mesa.tetra.cool {
	import log
	respond "my paws hurt :("
}

auth.mesa.tetra.cool {
	import log
	reverse_proxy {$AUTH_UPSTREAM}
}

home.mesa.tetra.cool {
	import log
	reverse_proxy 192.168.10.5:8123
}

jellyfin.mesa.tetra.cool {
	import log
	reverse_proxy {$JELLYFIN_UPSTREAM}
}

stats.mesa.tetra.cool {
	import log
	reverse_proxy {$STATS_UPSTREAM}
}

np.mesa.tetra.cool {
	import log
	reverse_proxy {$NP_UPSTREAM}
}

pve.mesa.tetra.cool {
	route {
		import lan_only
		reverse_proxy https://192.168.10.2:8006 {
			transport http {
				tls_insecure_skip_verify
			}
		}
	}
}

